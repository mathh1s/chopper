[Unit]
Description=chopper
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=chopper
Group=chopper
WorkingDirectory=/opt/chopper
EnvironmentFile=/opt/chopper/.env
ExecStart=/opt/chopper/chopper
Restart=always
RestartSec=3

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/chopper/data

[Install]
WantedBy=multi-user.target
