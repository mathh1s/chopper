# chopper config
#
# Do not fill this in by hand. Run scripts/gen-env.sh instead, which picks free
# random ports and generates the secrets for you. This file is only here to
# document what every key does.
#
# Nothing in docker-compose.yml is hardcoded. Every value below feeds into it.

# ==== ports ====

# Host side. What nginx proxies to. Keep it on 127.0.0.1 so nobody can reach
# the app directly and skip your SSL.
APP_BIND=127.0.0.1
APP_PORT=

# The port the Go server listens on inside the container. Compose turns this
# into ADDR=:<port> for you.
APP_INTERNAL_PORT=

# Only used if you uncomment the db ports block in docker-compose.yml.
# By default postgres is not published to the host at all.
DB_BIND=127.0.0.1
DB_PORT=

# ==== database ====

POSTGRES_VERSION=16-alpine
POSTGRES_USER=
POSTGRES_DB=
POSTGRES_PASSWORD=

# Only needed when running the binary outside compose. Compose builds this
# itself from the four values above.
# DATABASE_URL=postgres://user:pass@localhost:5432/db?sslmode=disable

# ==== auth ====

# The one shared password. Everyone who gets in types this.
AUTH_PASSWORD=

# Signs the session cookie. Any long random string.
# openssl rand -hex 32
SESSION_SECRET=

# ==== features ====

# Stem separation into drums, bass, vocals and other. On by default.
# WITH_DEMUCS is a build arg: it decides whether demucs goes into the image.
# DEMUCS_BIN is a runtime setting: empty hides the feature even if it is installed.
WITH_DEMUCS=1
DEMUCS_BIN=demucs
DEMUCS_MODEL=htdemucs

# ==== misc ====

# Where wav files and scratch downloads live inside the container.
DATA_DIR=/data

# Upload ceiling in megabytes. Keep nginx client_max_body_size above this.
MAX_UPLOAD_MB=300

# Set to false only if you are serving over plain http on localhost.
SECURE_COOKIE=true

# External binaries. Leave as is if they are on PATH.
YTDLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Serve the frontend from disk instead of the embedded copy, for css edits.
# WEB_DIR=./web/public
