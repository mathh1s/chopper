# chopper config
#
# Copy to .env and fill in. Everything without a default is required.

# ==== required ====

# Postgres connection string.
DATABASE_URL=postgres://chopper:changeme@localhost:5432/chopper?sslmode=disable

# The one shared password. Everyone who gets in types this.
AUTH_PASSWORD=

# Any long random string. Signs the session cookie.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# ==== compose only ====

# Used by docker-compose to build the DATABASE_URL above.
POSTGRES_PASSWORD=changeme

# ==== optional ====

# Listen address.
ADDR=:8080

# Where wav files and scratch downloads live.
DATA_DIR=./data

# Serve the frontend from disk instead of the embedded copy. Handy while editing css.
# WEB_DIR=./web/public

# Upload ceiling in megabytes.
MAX_UPLOAD_MB=300

# Set to false only if you are running over plain http on localhost.
SECURE_COOKIE=true

# External binaries. Leave as is if they are on PATH.
YTDLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Stem separation. Empty means the feature is hidden.
# Set to demucs (and install it) to get a split button in the library.
DEMUCS_BIN=
DEMUCS_MODEL=htdemucs

# Set to 1 when building the docker image if you want demucs baked in.
WITH_DEMUCS=0
